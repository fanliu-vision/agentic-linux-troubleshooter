# Project root.
PROJECT_ROOT=/home/lf/projects/agentic-linux-troubleshooter

# Python inside venv.
PYTHON_BIN=/home/lf/projects/agentic-linux-troubleshooter/.venv/bin/python

# Project registry config.
CONFIG_PATH=/home/lf/projects/agentic-linux-troubleshooter/configs/projects.yaml

# Agent options.
AGENT_DEPTH=balanced
REPORT_MODE=llm

# Stage 6E state and logs.
STATE_DIR=/home/lf/projects/agentic-linux-troubleshooter/state
DAEMON_LOG=/home/lf/projects/agentic-linux-troubleshooter/state/enterprise_demo_local/daemon.log

# Intervals.
HEARTBEAT_INTERVAL=60
HEALTH_CHECK_INTERVAL=300

# Optional LLM API key.
# Do not commit real API keys into git.
# OPENAI_API_KEY=sk-...