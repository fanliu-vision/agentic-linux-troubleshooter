# Copy to /etc/agentic-linux-troubleshooter/trace-ui.env via scripts/install_trace_ui_service.sh.
# Replace token values before exposing the UI beyond localhost.

PROJECT_ROOT=/home/lf/projects/agentic-linux-troubleshooter
PYTHON_BIN=/home/lf/projects/agentic-linux-troubleshooter/.venv/bin/python
CONFIG_PATH=/home/lf/projects/agentic-linux-troubleshooter/configs/projects.yaml
STATE_DIR=/home/lf/projects/agentic-linux-troubleshooter/state
OUTPUT_ROOT=/home/lf/projects/agentic-linux-troubleshooter/outputs/monitors

TRACE_UI_HOST=127.0.0.1
TRACE_UI_PORT=8765
SESSION_TTL_SECONDS=28800
WORKER_POLL_INTERVAL_SECONDS=1.5
TRACE_UI_EXTRA_ARGS=

# Backward-compatible admin token.
AGENTIC_TRACE_UI_TOKEN=change-me-admin-token

# Optional role tokens. Leave blank to use only AGENTIC_TRACE_UI_TOKEN.
AGENTIC_TRACE_UI_VIEWER_TOKEN=
AGENTIC_TRACE_UI_OPERATOR_TOKEN=
AGENTIC_TRACE_UI_APPROVER_TOKEN=
AGENTIC_TRACE_UI_ADMIN_TOKEN=
